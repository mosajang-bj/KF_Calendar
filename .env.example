# Redash API 설정 예시
# 이 파일을 복사해서 .env 로 만든 뒤 실제 값을 입력하세요.
#   cp .env.example .env
#
# Vercel 배포 시에는 .env 파일 대신
# Vercel Dashboard → Project → Settings → Environment Variables 에
# REDASH_API_KEY 를 직접 추가하면 됩니다.

REDASH_API_KEY=your_redash_api_key_here
REDASH_HOST=redash.bunjang.io

# Supabase service_role key (api/sync-shows.js, api/sync-youtube.js에서 upsert 시 필요)
# Supabase Dashboard → Project Settings → API → service_role (secret)
SUPA_SERVICE_KEY=your_supabase_service_role_key_here

# YouTube Data API v3 key (api/sync-youtube.js에서 뮤직뱅크/인기가요/엠카 수집 시 필요)
# Google Cloud Console → APIs & Services → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# 공방 일정 자동 수집 API 보호용 시크릿 (선택)
SYNC_SECRET=your_sync_secret_here
